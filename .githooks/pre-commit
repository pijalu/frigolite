#!/bin/sh
#
# Pre-commit hook: run quality gates and tests before allowing a commit.
# Install with: git config core.hooksPath .githooks
#
set -e

echo "=== Pre-commit checks ==="

# Run quality gate (vet, staticcheck, gocyclo, gocognit)
echo "--- Quality gate ---"
make quality 2>&1

# Run tests (exclude compatibility tests — they're slow and auto-generated)
echo "--- Tests ---"
go test -timeout 60s -count=1 -run "^Test[^C]" ./...

# Run SOLID architecture tests
echo "--- SOLID tests ---"
go test -timeout 30s -run "^TestSOLID_" .

echo "=== All checks passed ==="
