      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b NOT NULL AS (a+1))"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "10.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE abc ALTER b SET NOT NULL;"
        }
      ]
    },
    {
      "name": "10.2",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO abc VALUES(NULL);",
          "expect": "{1 {NOT NULL constraint failed: abc.b}}"
        }
      ]
    },
    {
      "name": "10.3",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO abc VALUES(3);\n  ALTER TABLE abc ALTER COLUMN b DROP NOT NULL;"
        }
      ]
    },
    {
      "name": "10.4",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO abc VALUES(NULL);",
          "expect": "#-------------------------------------------------------------------------"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "11.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a, b, c);"
        }
      ]
    },
    {
      "name": "11.1.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE t1 ADD CONSTRAINT c1 CHECK(a=b) --comment\n  ;"
        }
      ]
    },
    {
      "name": "11.1.2",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE t1 ADD CONSTRAINT c2 CHECK(a=b) --comment"
        }
      ]
    },
    {
      "name": "11.1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema;",
          "expect": "{\n  {CREATE TABLE t1(a, b, c, CONSTRAINT c1 CHECK(a=b), CONSTRAINT c2 CHECK(a=b))}"
        }
      ]
    },
    {
      "name": "11.2.1",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t2(a, b);",
          "expect": "do_execsql_test 11.2.2 {ALTER TABLE t2 ALTER b SET NOT NULL --new cons}"
        }
      ]
    },
    {
      "name": "11.2.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema WHERE name='t2';",
          "expect": "{\n  {CREATE TABLE t2(a, b NOT NULL)}"
        }
      ]
    },
    {
      "name": "11.2.3",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE t2 ALTER b DROP NOT NULL;\n  SELECT sql FROM sqlite_schema WHERE name='t2';",
          "expect": "{\n  {CREATE TABLE t2(a, b)}"
        }
      ]
    },
    {
      "name": "11.2.2",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE t2 ALTER b SET NOT NULL --new cons\n;",
          "expect": "#-------------------------------------------------------------------------"
        }
      ]
    },
    {
