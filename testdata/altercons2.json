      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "12.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE \"Test\" ( \n      \"IsActive\" INTEGER, \n      CONSTRAINT \"BooleanZeroOrOne\" CHECK (\"IsActive\" IN (0, 1)) \n  );"
        }
      ]
    },
    {
      "name": "12.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE Test DROP CONSTRAINT BooleanZeroOrOne"
        }
      ]
    },
    {
      "name": "12.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema",
          "expect": "{\n  {CREATE TABLE \"Test\" ( \n      \"IsActive\" INTEGER)}"
        }
      ]
    },
    {
      "name": "12.3",
      "steps": [
        {
          "type": "exec",
          "sql": "DROP TABLE Test;\n  CREATE TABLE \"Test\" ( \n      \"IsActive\" INTEGER, \n      CONSTRAINT \"BooleanZeroOrOne\" CHECK (\"IsActive\" IN (0, 1)) \n  );"
        }
      ]
    },
    {
      "name": "12.4",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE Test DROP CONSTRAINT \"BooleanZeroOrOne\""
        }
      ]
    },
    {
      "name": "12.5",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema",
          "expect": "{\n  {CREATE TABLE \"Test\" ( \n      \"IsActive\" INTEGER)}"
        }
      ]
    },
