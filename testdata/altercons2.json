{
  "file": "altercons2.test",
  "name": "altercons2",
  "tests": [
    {
      "name": "1.$tn.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema WHERE name='t1'",
          "expect": "[list $final]"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "2.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE x1(a PRIMARY KEY, b CHECK(a!=b) NOT NULL, c);"
        }
      ]
    },
    {
      "name": "2.1.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE x1 ADD CONSTRAINT ccc CHECK (a!='a')",
          "expect": "{1 {not authorized}}"
        }
      ]
    },
    {
      "name": "2.2.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE x1 ALTER c SET NOT NULL",
          "expect": "{1 {not authorized}}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "3.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x);"
        }
      ]
    },
    {
      "name": "3.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE t1 ALTER x SET NOT NULL;",
          "expect": "#-------------------------------------------------------------------------"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "4.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b, c, CONSTRAINT one CONSTRAINT two CHECK (b!=c));"
        }
      ]
    },
    {
      "name": "4.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE abc DROP CONSTRAINT one"
        }
      ]
    },
    {
      "name": "4.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema",
          "expect": "{\n  {CREATE TABLE abc(a, b, c, CONSTRAINT two CHECK (b!=c))}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "5.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b, c, CONSTRAINT two CHECK (b!=c), d)",
          "expect": "{1 {near \"d\": syntax error}}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "6.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b CONSTRAINT two COLLATE nocase CHECK (a!=b), c CONSTRAINT one DEFAULT 'abc');"
        }
      ]
    },
    {
      "name": "6.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE abc DROP CONSTRAINT one;\n  ALTER TABLE abc DROP CONSTRAINT two;"
        }
      ]
    },
    {
      "name": "6.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema",
          "expect": "{\n  {CREATE TABLE abc(a, b COLLATE nocase CHECK (a!=b), c DEFAULT 'abc')}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "7.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b, c, CONSTRAINT one CHECK (a>b) FOREIGN KEY(a) REFERENCES abc);"
        }
      ]
    },
    {
      "name": "7.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE abc DROP CONSTRAINT one"
        }
      ]
    },
    {
      "name": "7.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT sql FROM sqlite_schema",
          "expect": "{\n  {CREATE TABLE abc(a, b, c, FOREIGN KEY(a) REFERENCES abc)}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "8.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE abc(a, b, c, CONSTRAINT one FOREIGN KEY(a) REFERENCES abc);"
        }
      ]
    },
    {
      "name": "8.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ALTER TABLE abc DROP CONSTRAINT one",
          "expect": "{0 {}}"
        }
      ]
    },
