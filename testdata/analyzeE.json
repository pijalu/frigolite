      "name": "analyzeE-1.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a,b);\n  WITH RECURSIVE\n    cnt(x) AS (VALUES(1000) UNION ALL SELECT x+1 FROM cnt WHERE x<2000)\n  INSERT INTO t1(a,b) SELECT x, x FROM cnt;\n  CREATE INDEX t1a ON t1(a);\n  ANALYZE;",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "analyzeE-1.1",
      "steps": [
        {
          "type": "query",
          "sql": "EXPLAIN QUERY PLAN\n  SELECT * FROM t1 WHERE a BETWEEN 500 AND 2500;",
          "expect": "{/SCAN t1/}"
        }
      ]
    },
