{
  "file": "bestindex5.test",
  "name": "bestindex5",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "%QUERY%"
        }
      ]
    },
    {
      "name": "2.0.0",
      "steps": [
        {
          "type": "exec",
          "sql": "DELETE FROM t1x;\n  INSERT INTO t1x VALUES('a', 'b', 'c');",
          "expect": "do_execsql_test 2.0.1 { SELECT * FROM t1 } {a b c}"
        }
      ]
    },
    {
      "name": "2.1.0",
      "steps": [
        {
          "type": "exec",
          "sql": "DELETE FROM t1x;\n  INSERT INTO t1x VALUES(7, 8, 9);",
          "expect": "do_execsql_test 2.1.1 { SELECT * FROM t1 } {7 8 9.0}"
        }
      ]
    },
    {
      "name": "2.1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 WHERE (a, b) != (7, '8')",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "2.1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 WHERE a!=7 OR b!='8'"
        }
      ]
    },
    {
      "name": "2.1.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 WHERE a!=7 OR b!='8'"
        }
      ]
    },
    {
      "name": "2.2.1",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t3(a INTEGER, b TEXT);\n  INSERT INTO t3 VALUES(45, 46);",
          "expect": "do_execsql_test 2.2.2 { SELECT * FROM t3 WHERE (a, b) != (45, 46); }"
        }
      ]
    },
    {
      "name": "2.2.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t3 WHERE (a, b) != ('45', '46');",
          "expect": "do_execsql_test 2.2.4 { SELECT * FROM t3 WHERE (a, b) == (45, 46); } {45 46}"
        }
      ]
    },
    {
      "name": "3.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT rowid, * FROM t4 WHERE x='245';",
          "expect": "{1 245}"
        }
      ]
    },
    {
      "name": "3.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT rowid, * FROM t4 WHERE x!=245;",
          "expect": "{}"
        }
      ]
    }
  ]
}