          "sql": "SELECT * FROM v1",
          "expect": "{1 {no such table: v1}}"
        }
      ]
    },
    {
      "name": "3.5.0",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM aux.v2",
          "expect": "{{a aux} {b aux}}"
        }
      ]
    },
    {
