{
  "file": "e_resolve.test",
  "name": "e_resolve",
  "tests": [
    {
      "name": "1.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM n1",
          "expect": "{temp n1}"
        }
      ]
    },
    {
      "name": "1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM n2",
          "expect": "{main n2}"
        }
      ]
    },
    {
      "name": "1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM n3",
          "expect": "{at1  n3}"
        }
      ]
    },
    {
      "name": "2.1.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM main.n1",
          "expect": "{main n1}"
        }
      ]
    },
    {
      "name": "2.1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM temp.n1",
          "expect": "{temp n1}"
        }
      ]
    },
    {
      "name": "2.1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM at1.n1",
          "expect": "{at1 n1}"
        }
      ]
    },
    {
      "name": "3.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM MAIN.n1",
          "expect": "{main n1}"
        }
      ]
    },
    {
      "name": "3.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM tEmP.n1",
          "expect": "{temp n1}"
        }
      ]
    },
    {
      "name": "3.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM aT1.n1",
          "expect": "{at1 n1}"
        }
      ]
    },
    {
      "name": "4.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM temp.n2",
          "expect": "{1 {no such table: temp.n2}}"
        }
      ]
    },
    {
      "name": "4.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM main.n2",
          "expect": "{0 {main n2}}"
        }
      ]
    },
    {
      "name": "4.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM at1.n2",
          "expect": "{0 {at1 n2}}"
        }
      ]
    },
    {
      "name": "5.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM n3",
          "expect": "{at1  n3}"
        }
      ]
    },
    {
      "name": "6.1",
      "steps": [
        {
          "type": "exec",
          "sql": "ATTACH 'file.db' AS aux;\n  CREATE TABLE t1(x, y);\n  CREATE TEMP TABLE t1(x, y);\n  CREATE TABLE aux.t1(x, y);",
          "expect": "do_execsql_test  6.2.0 { DROP TABLE t1 }"
        }
      ]
    },
    {
      "name": "6.2.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM temp.t1",
          "expect": "{1 {no such table: temp.t1}}"
        }
      ]
    },
    {
      "name": "6.2.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM main.t1",
          "expect": "{0 {}}"
        }
      ]
    },
    {
      "name": "6.3.0",
      "steps": [
        {
          "type": "exec",
          "sql": "DROP TABLE t1",
          "expect": "do_catchsql_test 6.3.1 { SELECT * FROM main.t1 } {1 {no such table: main.t1}}"
        }
      ]
    },
    {
      "name": "6.4.0",
      "steps": [
        {
          "type": "exec",
          "sql": "DROP TABLE t1"
        }
      ]
    }
  ]
}