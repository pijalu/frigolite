{
  "file": "e_wal.test",
  "name": "e_wal",
  "tests": [
    {
      "name": "1.1.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = WAL;",
          "expect": "{delete}"
        }
      ]
    },
    {
      "name": "1.1.3",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x, y);\n  INSERT INTO t1 VALUES(1, 2);",
          "expect": "{}"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        },
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(3, 4)"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        }
      ]
    },
    {
      "name": "2.3.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = DELETE;\n  SELECT * FROM t1;",
          "expect": "{delete 1 2 3 4}"
        },
        {
          "type": "exec",
          "sql": "PRAGMA journal_mode = WAL"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "4.1.1",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x, y)",
          "expect": "do_test 4.1.2 { hexio_read test.db 18 2 } {0101}"
        }
      ]
    },
    {
      "name": "4.1.3",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = wAL",
          "expect": "{wal}"
        }
      ]
    },
    {
      "name": "4.2.1",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(1, 1);",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "4.2.3",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = delete",
          "expect": "{delete}"
        }
      ]
    }
  ]
}