{
  "file": "filefmt.test",
  "name": "filefmt",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x)"
        },
        {
          "type": "exec",
          "sql": "PRAGMA auto_vacuum=OFF"
        },
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x)"
        },
        {
          "type": "exec",
          "sql": "PRAGMA page_size=512; CREATE TABLE t1(x)"
        }
      ]
    },
    {
      "name": "filefmt-2.1.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA page_size = 1024;\n  PRAGMA auto_vacuum = 0;\n  CREATE TABLE t1(a);\n  CREATE INDEX i1 ON t1(a);\n  INSERT INTO t1 VALUES(a_string(3000));\n  CREATE TABLE t2(a);\n  INSERT INTO t2 VALUES(1);",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "filefmt-2.1.4",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t2 VALUES(2)",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "filefmt-2.2.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA page_size = 1024;\n  PRAGMA auto_vacuum = 0;\n  CREATE TABLE t1(a);\n  CREATE INDEX i1 ON t1(a);\n  INSERT INTO t1 VALUES(a_string(3000));\n  CREATE TABLE t2(a);\n  INSERT INTO t2 VALUES(1);",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "filefmt-2.2.6",
      "steps": [
        {
          "type": "exec",
          "sql": "COMMIT",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "filefmt-3.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA auto_vacuum = 1;\n  CREATE TABLE t1(a, b);",
          "expect": "{}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    }
  ]
}