{
  "file": "hexlit.test",
  "name": "hexlit",
  "tests": [
    {
      "name": "hexlit-300",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x INT, y REAL);\n  INSERT INTO t1 VALUES('1234','4567'),('0x1234','0x4567');\n  SELECT typeof(x), x, typeof(y), y, '#' FROM t1 ORDER BY rowid;",
          "expect": "{integer 1234 real 4567.0 # text 0x1234 text 0x4567 #}"
        }
      ]
    },
    {
      "name": "hexlist-400",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT 0x10000000000000000;",
          "expect": "{1 {hex literal too big: 0x10000000000000000}}"
        }
      ]
    },
    {
      "name": "hexlist-401",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT DISTINCT 0x10000000000000000;",
          "expect": "{1 {hex literal too big: 0x10000000000000000}}"
        }
      ]
    },
    {
      "name": "hexlist-402",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT DISTINCT -0x08000000000000000;",
          "expect": "{1 {hex literal too big: -0x08000000000000000}}"
        }
      ]
    }
  ]
}