{
  "file": "jrnlmode2.test",
  "name": "jrnlmode2",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "PRAGMA journal_mode = persist;\n    CREATE TABLE t1(a, b);\n    INSERT INTO t1 VALUES(1, 2);"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        },
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(3, 4);"
        },
        {
          "type": "exec",
          "sql": "BEGIN;\n    SELECT * FROM t1;"
        },
        {
          "type": "exec",
          "sql": "PRAGMA lock_status"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        },
        {
          "type": "exec",
          "sql": "PRAGMA journal_mode = truncate"
        },
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(5, 6)"
        }
      ]
    }
  ]
}