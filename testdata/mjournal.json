{
  "file": "mjournal.test",
  "name": "mjournal",
  "tests": [
    {
      "name": "1.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a, b);"
        }
      ]
    },
    {
      "name": "1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1;"
        }
      ]
    },
    {
      "name": "1.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1;",
          "expect": "# And now test that nothing bad happens if a master journal contains a"
        }
      ]
    },
    {
      "name": "1.6",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1;",
          "expect": "#-------------------------------------------------------------------------"
        }
      ]
    },
    {
      "name": "2.0",
      "steps": [
        {
          "type": "exec",
          "sql": "ATTACH 'test.db2' AS dbfile;\n  ATTACH ''         AS dbtemp;\n  ATTACH ':memory:'  AS dbmem;\n\n  CREATE TABLE t1(x);\n  CREATE TABLE dbfile.t2(x);\n  CREATE TABLE dbtemp.t3(x);\n  CREATE TABLE dbmem.t4(x);",
          "expect": "# Two real files."
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "3.0",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA synchronous = OFF;\n  CREATE TABLE t1(x, y);"
        }
      ]
    },
    {
      "name": "3.1",
      "steps": [
        {
          "type": "exec",
          "sql": "BEGIN;\n    INSERT INTO t1 VALUES(100, 200);",
          "expect": "db_save"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "4.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x INTEGER PRIMARY KEY);"
        },
        {
          "type": "exec",
          "sql": "PRAGMA synchronous = OFF;\n      BEGIN;\n        INSERT INTO t1 DEFAULT VALUES;"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        }
      ]
    }
  ]
}