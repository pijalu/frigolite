{
  "file": "printf2.test",
  "name": "printf2",
  "tests": [
    {
      "name": "printf2-1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT printf('hello');",
          "expect": "{hello}"
        }
      ]
    },
    {
      "name": "printf2-1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT format('%d,%d,%d',55,-11,3421);",
          "expect": "{55,-11,3421}"
        }
      ]
    },
    {
      "name": "printf2-1.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT printf('%d,%d,%d',55,'-11',3421);",
          "expect": "{55,-11,3421}"
        }
      ]
    },
    {
      "name": "printf2-1.5",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT format('%d,%d,%d,%d',55,'-11',3421);",
          "expect": "{55,-11,3421,0}"
        }
      ]
    },
    {
      "name": "printf2-1.6",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT printf('%.2f',3.141592653);",
          "expect": "{3.14}"
        }
      ]
    },
    {
      "name": "printf2-1.7",
      "steps": [
        {
          "type": "query",
