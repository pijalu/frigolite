      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA writable_schema = 1;\n  DELETE FROM sqlite_master WHERE name='t1';"
        }
      ]
    },
    {
      "name": "2.3.0",
      "steps": [
        {
          "type": "exec",
