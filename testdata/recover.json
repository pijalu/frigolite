      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a, b, c);\n  CREATE TABLE t2(d, e, f);\n  CREATE TABLE t3(g, h, i);\n\n  INSERT INTO t2 VALUES(1, 2, 3);\n  INSERT INTO t2 VALUES('a', 'b', 'c');\n\n  INSERT INTO t3 VALUES('one', 'two', 'three');\n  DROP TABLE t1;\n  DROP TABLE t2;",
