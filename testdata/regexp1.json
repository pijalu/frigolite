{
  "file": "regexp1.test",
  "name": "regexp1",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x INTEGER PRIMARY KEY, y TEXT);\n    INSERT INTO t1 VALUES(1, 'For since by man came death,');\n    INSERT INTO t1 VALUES(2, 'by man came also the resurrection of the dead.');\n    INSERT INTO t1 VALUES(3, 'For as in Adam all die,');\n    INSERT INTO t1 VALUES(4, 'even so in Christ shall all be made alive.');\n\n    SELECT x FROM t1 WHERE y REGEXP '^For ' ORDER BY x;"
        }
      ]
    },
    {
      "name": "regexp1-1.1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT regexpi('abc','ABC');",
          "expect": "{1}"
        }
      ]
    },
