{
  "file": "rowvaluevtab.test",
  "name": "rowvaluevtab",
  "tests": [
    {
      "name": "1.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT a FROM e1 WHERE (b, c) = (2, 2)",
          "expect": "{five}"
        }
      ]
    },
    {
      "name": "1.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT a FROM e1 WHERE (b, c) > (2, 2)",
          "expect": "{six seven eight nine}"
        }
      ]
    },
    {
      "name": "1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT a FROM e1 WHERE (b, c) >= (2, 2)",
          "expect": "{five six seven eight nine}"
        }
      ]
    },
    {
      "name": "1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT a FROM e1 WHERE (b, c) BETWEEN (1, 2) AND (2, 3)",
          "expect": "{two three four five six}"
        }
      ]
    },
    {
      "name": "1.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT a FROM e1 WHERE (b, c) IN ( VALUES(2, 2) )",
          "expect": "{five}"
        }
      ]
    }
  ]
}