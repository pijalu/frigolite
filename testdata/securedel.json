          "sql": "PRAGMA secure_delete=FAST;\n    PRAGMA db2.secure_delete;"
        },
        {
          "type": "exec",
          "sql": "PRAGMA secure_delete=ON;\n    PRAGMA db2.secure_delete;"
        },
        {
