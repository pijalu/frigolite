{
  "file": "securedel2.test",
  "name": "securedel2",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "PRAGMA secure_delete = 1"
        },
        {
          "type": "exec",
          "sql": "PRAGMA auto_vacuum = 0"
        },
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x, y)"
        }
      ]
    },
    {
      "name": "1.3.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA secure_delete = 0",
          "expect": "{0}"
        }
      ]
    },
    {
      "name": "1.3.2",
      "steps": [
        {
          "type": "exec",
          "sql": "DELETE FROM t1 WHERE rowid = 1"
        }
      ]
    },
    {
      "name": "1.4.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA secure_delete = 1",
          "expect": "{1}"
        }
      ]
    },
    {
      "name": "1.4.2",
      "steps": [
        {
          "type": "exec",
          "sql": "DELETE FROM t1 WHERE rowid = 1"
        }
      ]
    },
    {
      "name": "1.5.1",
      "steps": [
        {
          "type": "exec",
          "sql": "DELETE FROM t1 WHERE rowid>850",
          "expect": "{}"
        },
        {
          "type": "exec",
          "sql": "PRAGMA cache_size = 200;\n    PRAGMA secure_delete = 1;\n    CREATE TABLE t2(x);\n    SELECT * FROM t1;"
        },
        {
          "type": "exec",
          "sql": "DELETE FROM t1"
        }
      ]
    }
  ]
}