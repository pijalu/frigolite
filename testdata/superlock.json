{
  "file": "superlock.test",
  "name": "superlock",
  "tests": [
    {
      "name": "1.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "2.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "2.4",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(5, 6)",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "3.1",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(3, 4)",
          "expect": "do_test 3.2 { sqlite3demo_superlock unlock test.db } {unlock}"
        }
      ]
    },
    {
      "name": "3.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "3.4",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(5, 6)",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "4.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "4.4",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(5, 6)",
          "expect": "{1 {database is locked}}"
        }
      ]
    },
    {
      "name": "6.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {no such table: t1}}"
        }
      ]
    },
    {
      "name": "6.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{0 {1 2 3 4}}"
        }
      ]
    },
    {
      "name": "6.7",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {no such table: t1}}"
        }
      ]
    },
    {
      "name": "6.9",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{0 {1 2 3 4}}"
        }
      ]
    },
    {
      "name": "6.11codec",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = delete;\n    VACUUM;\n    PRAGMA journal_mode = wal;\n    INSERT INTO t1 VALUES(5, 6);",
          "expect": "{delete wal}"
        }
      ]
    },
    {
      "name": "6.11",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = delete;\n    PRAGMA page_size = 512;\n    VACUUM;\n    PRAGMA journal_mode = wal;\n    INSERT INTO t1 VALUES(5, 6);",
          "expect": "{delete wal}"
        }
      ]
    },
    {
      "name": "6.12",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 {no such table: t1}}"
        }
      ]
    },
    {
      "name": "6.14",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{0 {1 2 3 4 5 6}}"
        }
      ]
    }
  ]
}