{
  "file": "sync2.test",
  "name": "sync2",
  "tests": [
    {
      "name": "1.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a, b);\n  INSERT INTO t1 VALUES(1, 2);"
        }
      ]
    },
    {
      "name": "1.2.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous = NORMAL",
          "expect": "do_execsql_test      1.2.2 { PRAGMA main.synchronous }     1"
        }
      ]
    },
    {
      "name": "1.3.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous = OFF",
          "expect": "do_execsql_test      1.3.2 { PRAGMA main.synchronous }     0"
        }
      ]
    },
    {
      "name": "1.4.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous = FULL",
          "expect": "do_execsql_test      1.4.2 { PRAGMA main.synchronous }      2"
        }
      ]
    },
    {
      "name": "1.8.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous = NORMAL",
          "expect": "do_execsql_test      1.8.2 { PRAGMA main.synchronous }          1"
        }
      ]
    },
    {
      "name": "1.10.1",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous = OFF",
          "expect": "do_execsql_test      1.10.2 { PRAGMA main.synchronous }          0"
        }
      ]
    },
    {
      "name": "1.20.3",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA main.synchronous",
          "expect": "2"
        }
      ]
    }
  ]
}