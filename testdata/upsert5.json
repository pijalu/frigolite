{
  "file": "upsert5.test",
  "name": "upsert5",
  "tests": [
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "2.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t2(a, b, c REAL, d, e, PRIMARY KEY(a,b)) WITHOUT ROWID;\n  CREATE UNIQUE INDEX t2c ON t2(c);"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "3.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 NOT INDEXED;",
          "expect": "{11 33}"
        }
      ]
    },
    {
      "name": "3.2",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 INDEXED BY t1bb;",
          "expect": "{11 33}"
        }
      ]
    },
    {
      "name": "3.4",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 NOT INDEXED ORDER BY +aa;",
          "expect": "{10 21 32 11 44 55 12 23 34}"
        }
      ]
    },
    {
      "name": "3.5",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1 INDEXED BY t1bb ORDER BY +aa;",
          "expect": "{10 21 32 11 44 55 12 23 34}"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "4.$tn.3",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1;",
          "expect": "{555 22.0 555.0 555 555}"
        }
      ]
    },
    {
      "name": "4.3.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t2(a, b GENERATED ALWAYS AS (a+1) VIRTUAL, c REAL, d UNIQUE);\n  INSERT INTO t2(a, c, d) VALUES(555, 555, 555);"
        }
      ]
    }
  ]
}