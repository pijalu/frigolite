{
  "file": "vacuum2.test",
  "name": "vacuum2",
  "tests": [
    {
      "name": "setup_0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x INTEGER PRIMARY KEY AUTOINCREMENT, y);\n    DROP TABLE t1;\n    VACUUM;"
        },
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x);\n    CREATE TABLE t2(y);\n    INSERT INTO t1 VALUES(1);"
        },
        {
          "type": "exec",
          "sql": "VACUUM"
        },
        {
          "type": "exec",
          "sql": "pragma page_size"
        },
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES('hello');\n    INSERT INTO t2 VALUES('out there');"
        },
        {
          "type": "exec",
          "sql": "PRAGMA auto_vacuum=FULL;\n      VACUUM;"
        },
        {
          "type": "exec",
          "sql": "PRAGMA integrity_check"
        },
        {
          "type": "exec",
          "sql": "PRAGMA integrity_check"
        },
        {
          "type": "exec",
          "sql": "PRAGMA auto_vacuum=NONE;\n    VACUUM;"
        },
        {
          "type": "exec",
          "sql": "PRAGMA integrity_check"
        },
        {
          "type": "exec",
          "sql": "PRAGMA integrity_check"
        },
        {
          "type": "exec",
          "sql": "pragma auto_vacuum=1;\n      create table t(a, b);\n      insert into t values(1, 2);\n      insert into t values(1, 2);\n      pragma auto_vacuum=0;\n      vacuum;\n      pragma auto_vacuum;"
        },
        {
          "type": "exec",
          "sql": "pragma auto_vacuum=1;\n      vacuum;\n      pragma auto_vacuum;"
        },
        {
          "type": "exec",
          "sql": "pragma integrity_check"
        },
        {
          "type": "exec",
          "sql": "pragma auto_vacuum;"
        },
        {
          "type": "exec",
          "sql": "pragma auto_vacuum=2;\n      vacuum;\n      pragma auto_vacuum;"
        },
        {
          "type": "exec",
          "sql": "pragma integrity_check"
        },
        {
          "type": "exec",
          "sql": "pragma auto_vacuum;"
        },
        {
          "type": "exec",
          "sql": "SELECT a, b FROM t1"
        },
        {
          "type": "exec",
          "sql": "SELECT 1, 2, 3"
        },
        {
          "type": "exec",
          "sql": "SELECT a, b FROM t1 WHERE a<=10"
        }
      ]
    },
    {
      "name": "6.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t6(x PRIMARY KEY COLLATE cmp, y) WITHOUT ROWID;\n  CREATE INDEX t6y ON t6(y);\n  INSERT INTO t6 VALUES('i', 'one');\n  INSERT INTO t6 VALUES('ii', 'one');\n  INSERT INTO t6 VALUES('iii', 'one');",
          "expect": "integrity_check 6.1"
        }
      ]
    }
  ]
}