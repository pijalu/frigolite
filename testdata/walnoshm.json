{
  "file": "walnoshm.test",
  "name": "walnoshm",
  "tests": [
    {
      "name": "1.1",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(x, y);\n  INSERT INTO t1 VALUES(1, 2);"
        }
      ]
    },
    {
      "name": "1.2",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = WAL;\n  SELECT * FROM t1;",
          "expect": "{delete 1 2}"
        }
      ]
    },
    {
      "name": "1.6",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(3, 4)"
        }
      ]
    },
    {
      "name": "1.8",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = delete;\n  PRAGMA main.locking_mode;",
          "expect": "{delete exclusive}"
        }
      ]
    },
    {
      "name": "1.10",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1;",
          "expect": "{1 2 3 4}"
        }
      ]
    },
    {
      "name": "2.1.1",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t2(x, y);\n  INSERT INTO t2 VALUES('a', 'b');\n  INSERT INTO t2 VALUES('c', 'd');"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t2"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t2"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t2"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t2"
        },
        {
          "type": "exec",
          "sql": "SELECT * FROM t1"
        }
      ]
    }
  ]
}