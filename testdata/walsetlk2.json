{
  "file": "walsetlk2.test",
  "name": "walsetlk2",
  "tests": [
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "1.0",
      "steps": [
        {
          "type": "query",
          "sql": "PRAGMA journal_mode = wal;\n  CREATE TABLE t1(a, b, c);\n  INSERT INTO t1 VALUES(1, 2, 3);",
          "expect": "{wal}"
        }
      ]
    },
    {
      "name": "1.2",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(4, 5, 6);",
          "expect": "set ::xshmlock [list]"
        }
      ]
    },
    {
      "name": "1.3",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(7, 8, 9);"
        }
      ]
    },
    {
      "name": "1.5.1",
      "steps": [
        {
          "type": "query",
          "sql": "SELECT * FROM t1",
          "expect": "{1 2 3 4 5 6 7 8 9}"
        }
      ]
    },
    {
      "name": "1.5.2",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(10, 11, 12);"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "2.0",
      "steps": [
        {
          "type": "exec",
          "sql": "CREATE TABLE t1(a, b);\n  INSERT INTO t1 VALUES(1, 2), (3, 4);"
        },
        {
          "type": "exec",
          "sql": "BEGIN EXCLUSIVE;\n      INSERT INTO t1 VALUES(5, 6);"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        }
      ]
    },
    {
      "name": "2.5",
      "steps": [
        {
          "type": "exec",
          "sql": "INSERT INTO t1 VALUES(9, 10);"
        },
        {
          "type": "exec",
          "sql": "BEGIN EXCLUSIVE;\n      INSERT INTO t1 VALUES(11, 12);"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        }
      ]
    },
    {
      "name": "__RESET_DB__",
      "steps": [
        {
          "type": "reset_db"
        }
      ]
    },
    {
      "name": "setup_10",
      "steps": [
        {
          "type": "exec",
          "sql": "BEGIN EXCLUSIVE;\n      INSERT INTO t1 VALUES(5, 'five');"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        },
        {
          "type": "exec",
          "sql": "BEGIN EXCLUSIVE;\n      INSERT INTO t1 VALUES(9, 'nine');"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        },
        {
          "type": "exec",
          "sql": "BEGIN EXCLUSIVE;\n      INSERT INTO t1 VALUES(11, 'eleven');"
        },
        {
          "type": "exec",
          "sql": "COMMIT"
        }
      ]
    }
  ]
}